FB_GRAPH_TOKEN=...
FB_PAGE_ID=...
FB_GRAPH_VERSION=v24.0
FB_GRAPH_BASE=https://graph.facebook.com

CH_HOST=host.docker.internal
CH_PORT=8123
CH_USER=default
CH_PASSWORD=default
CH_DATABASE=instagram_etl
CH_SECURE=false
CH_CLUSTER=
# Optional failover nodes (host:port), comma-separated.
# CH_ALT_HOSTS=ch-node-2:8123,ch-node-3:8123

FB_INITIAL_SYNC_START_AT=2026-01-01T00:00:00Z
FB_BACKFILL_CHUNK_DAYS=60
FB_MAX_WINDOWS_PER_RUN=1
FB_SYNC_LOOKBACK_HOURS=24

FB_POSTS_PAGE_SIZE=100
FB_COMMENTS_PAGE_SIZE=100
FB_COMMENTS_POST_SCAN_LIMIT=200
FB_MAX_POST_INSIGHT_REQUESTS=200

# Optional
# FB_DISABLE_COMMENTS=false
# FB_DISABLE_PAGE_INSIGHTS=false
# FB_DISABLE_POST_INSIGHTS=false
