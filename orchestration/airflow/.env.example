# Airflow image/runtime
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3-python3.11
# Set to host uid for local bind-mounted paths.
# Example: on macOS/Linux run `id -u`
AIRFLOW_UID=50000
AIRFLOW_GID=0
# Container runtime user for Airflow services.
# Use 0:0 on Linux when Docker socket permissions are inconsistent.
AIRFLOW_DOCKER_USER=0:0
# Host docker group id so Airflow services can access /var/run/docker.sock.
# On Linux: getent group docker | cut -d: -f3
DOCKER_GID=998

# Airflow web UI
AIRFLOW_WEB_PORT=8088
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
AIRFLOW_WWW_USER_EMAIL=admin@example.com

# Airflow metadata DB (local dev only)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Install extra providers at container startup (local dev convenience).
# For production, build a custom Airflow image instead.
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-docker

# IG ETL runtime config used by DAGs.
IG_ETL_IMAGE=ig-etl:dev-local
IG_ETL_ENV_FILE_HOST_PATH=/Users/mdot/Documents/dev/meta-etl/.prod.env
IG_ETL_DAG_CRON=0 4 * * *

# Connectivity mode between DockerOperator-launched ETL container and ClickHouse.
# `bridge` expects CH_HOST=host.docker.internal (with host-gateway mapping below).
# On Linux you can also use `host` mode with CH_HOST=127.0.0.1.
IG_ETL_DOCKER_NETWORK_MODE=bridge
IG_ETL_EXTRA_HOST_MAPPING=host.docker.internal:host-gateway

# Optional overrides passed directly to the ETL container.
# These take precedence over values inside IG_ETL_ENV_FILE_HOST_PATH.
# IG_ETL_CH_HOST=host.docker.internal
# IG_ETL_CH_PORT=8123
# IG_ETL_CH_SECURE=false
