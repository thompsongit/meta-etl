AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3-python3.11
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_DOCKER_USER=50000:0
# Host docker group id so Airflow services can access /var/run/docker.sock.
# On Linux: stat -c '%g' /var/run/docker.sock
DOCKER_GID=998

AIRFLOW_WEB_PORT=8088
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
AIRFLOW_WWW_USER_EMAIL=admin@admin.com
AIRFLOW__WEBSERVER__BASE_URL=https://xyz.org/airflow
AIRFLOW__WEBSERVER__ENABLE_PROXY_FIX=True
AIRFLOW__WEBSERVER__PROXY_FIX_X_FOR=1
AIRFLOW__WEBSERVER__PROXY_FIX_X_HOST=1
AIRFLOW__WEBSERVER__PROXY_FIX_X_PROTO=1
AIRFLOW__WEBSERVER__PROXY_FIX_X_PREFIX=1


POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-docker

# IG ETL runtime config used by DAGs.
IG_ETL_IMAGE=ig-etl:dev-local
IG_ETL_ENV_FILE_HOST_PATH=/home/dev/meta-etl/.prod.env
IG_ETL_DAG_CRON=0 4 * * *
IG_ETL_DOCKER_NETWORK_MODE=host
IG_ETL_CH_HOST=127.0.0.1
IG_ETL_CH_PORT=8123
IG_ETL_CH_SECURE=false
# Optional cluster-aware pass-through overrides to the ETL container:
# IG_ETL_CH_CLUSTER=main_cluster
# IG_ETL_CH_ALT_HOSTS=ch-node-2:8123,ch-node-3:8123
